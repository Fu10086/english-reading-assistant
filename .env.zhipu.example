# 智谱 API 配置示例
# 复制这个文件为 .env 并填入你的 API Key

# API 类型：zhipu 或 anthropic
API_TYPE=zhipu

# 智谱 API Key（从 https://open.bigmodel.cn/ 获取）
ZHIPU_API_KEY=你的智谱API_Key

# 智谱模型选择
# glm-4: 标准版，性能均衡
# glm-4-plus: 增强版，效果更好但更贵
# glm-4-flash: 快速版，速度快但效果稍弱
ZHIPU_MODEL=glm-4

# 智谱 API 地址（通常不需要改）
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
